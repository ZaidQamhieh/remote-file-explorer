# Go agent
/agent/bin/
/agent/agent
*.exe

# TLS / local state (never commit)
*.pem
agent.db
agent.db-*

# Flutter / Dart
/app/.dart_tool/
/app/.flutter-plugins
/app/.flutter-plugins-dependencies
/app/build/
/app/.idea/
/app/ios/Pods/
/app/android/.gradle/
/app/**/GeneratedPluginRegistrant.*
*.iml

# OS / editor
.DS_Store
Thumbs.db
.vscode/
# JetBrains project state: generated per-machine (SDK paths, device caches,
# resolved Dart packages), so it churns for every user and is regenerated on
# open. /app/.idea/ was already ignored; the root one was tracked by oversight.
/.idea/

# Agent worktrees (local scratch space, never commit)
/.claude/worktrees/

# Personal Claude Code settings (per-user, not team config)
/.claude/settings.local.json

# Generated knowledge-graph artifact (regenerate with tools/rebuild-graph.sh)
/graphify-out/

# Web companion Tailwind build tooling (compiled output ships in dist/tailwind.css)
/agent/internal/webui/node_modules/
