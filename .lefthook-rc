# Sourced by lefthook before running hooks (see `rc:` in lefthook.yml).
# Puts the Go and Flutter toolchains on PATH for hooks launched from IDEs /
# non-login shells. Adjust paths if your toolchains live elsewhere.
export PATH="$HOME/.local/go/bin:$HOME/flutter/bin:$HOME/go/bin:$PATH"

# Unset GIT_DIR/GIT_WORK_TREE so that `flutter` (which internally runs
# `git -C $FLUTTER_ROOT rev-parse HEAD`) doesn't get confused by lefthook's
# worktree-scoped GIT_DIR and rebuild with version 0.0.0-unknown.
unset GIT_DIR GIT_WORK_TREE
